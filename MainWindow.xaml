<Window x:Class="AntigravityFPSOptimizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Kernel FPS Artırma - Mustik Dev" 
        Height="580" Width="850"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- Modern Toggle Switch Style -->
        <Style x:Key="ModernToggleStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="Grid" Background="Transparent" Cursor="Hand">
                            <Border x:Name="BgBorder" Width="46" Height="24" Background="#25FFFFFF" CornerRadius="12" SnapsToDevicePixels="True" BorderThickness="1.5" BorderBrush="#15FFFFFF">
                                <Ellipse x:Name="Dot" Width="16" Height="16" Fill="#FFAAAAAA" HorizontalAlignment="Left" Margin="3,0,0,0">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform x:Name="Trans" X="0"/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.3"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#00FFCC"/>
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="#00FFCC"/>
                                <Setter TargetName="Dot" Property="Fill" Value="#0A0E1A"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Trans" Storyboard.TargetProperty="X" To="22" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Trans" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Accent Buttons -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#FFAAAAAA"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Padding" Value="15,0,0,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderThickness="0" CornerRadius="8" Margin="0,2">
                            <Grid>
                                <Rectangle x:Name="Indicator" Width="4" Height="20" Fill="#00FFCC" HorizontalAlignment="Left" Visibility="Collapsed"/>
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#15FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#25FFFFFF"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsVisible, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=TabItem}}" Value="True">
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="White"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Action Button -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00FFCC"/>
            <Setter Property="Foreground" Value="#0A0E1A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00E6B8"/>
                                <Setter TargetName="Border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00FFCC" BlurRadius="12" ShadowDepth="0" Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#FF333333"/>
                                <Setter Property="Foreground" Value="#FF777777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek Glass Progress Bar Style -->
        <Style x:Key="NeonProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="Foreground">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#00FFCC" Offset="0"/>
                        <GradientStop Color="#0099FF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot" SnapsToDevicePixels="true">
                            <Border CornerRadius="6" Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}"/>
                            <Grid x:Name="AnimationVolume" ClipToBounds="true" Margin="1">
                                <Border x:Name="Indicator" CornerRadius="5" Background="{TemplateBinding Foreground}" HorizontalAlignment="Left"/>
                            </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter TargetName="Indicator" Property="HorizontalAlignment" Value="Stretch"/>
                                <Setter TargetName="Indicator" Property="VerticalAlignment" Value="Bottom"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Profile Radio Button Style -->
        <Style x:Key="ProfileRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="#10FFFFFF"/>
            <Setter Property="Foreground" Value="#FFAAAAAA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#15FFFFFF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Margin="3,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1500FFCC"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#00FFCC"/>
                                <Setter Property="Foreground" Value="#00FFCC"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="Border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00FFCC" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#44FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Container Outer Shadow -->
    <Border CornerRadius="12" Margin="10" BorderThickness="1" BorderBrush="#35FFFFFF">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="0" Opacity="0.8"/>
        </Border.Effect>

        <!-- Main Acrylic Background -->
        <Grid>
            <!-- Background Gradients -->
            <Border CornerRadius="11" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0.1,0" EndPoint="0.9,1">
                        <GradientStop Color="#0A0E1A" Offset="0"/>
                        <GradientStop Color="#12182D" Offset="0.5"/>
                        <GradientStop Color="#0D1325" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Inner Layout Grid -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ================== SIDEBAR ================== -->
                <Border Grid.Column="0" Background="#10FFFFFF" CornerRadius="11,0,0,11" BorderBrush="#15FFFFFF" BorderThickness="0,0,1,0">
                    <Grid Margin="15,20,15,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Logo / Title -->
                        <Grid Grid.Row="0" Margin="5,0,0,25" HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Glowing Vector Lightning Shield Logo -->
                            <Grid Grid.Column="0" Width="36" Height="36" Margin="0,0,10,0">
                                <Ellipse Fill="#1500FFCC" Stroke="#FF00FFCC" StrokeThickness="1.5">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#00FFCC" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <Path Data="M20,6 L12,22 L19,22 L15,34 L28,18 L21,18 Z" Fill="#FF00FFCC" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" Width="14" Height="18">
                                    <Path.Effect>
                                        <DropShadowEffect Color="#00FFCC" BlurRadius="4" ShadowDepth="0" Opacity="0.8"/>
                                    </Path.Effect>
                                </Path>
                            </Grid>
                            <!-- Title Text -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="MUSTIK DEV" FontSize="16" FontWeight="Bold" Foreground="White">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#00FFCC" BlurRadius="6" ShadowDepth="0" Opacity="0.4"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="KERNEL FPS ARTIRMA" FontSize="9" Foreground="#00FFCC" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>

                        <!-- Navigation Menu -->
                        <StackPanel Grid.Row="1" VerticalAlignment="Top">
                            <Button Style="{StaticResource SidebarButtonStyle}" Tag="Dashboard" Click="TabButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏠  Ana Sayfa" FontSize="13" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButtonStyle}" Tag="Tweaks" Click="TabButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡  Optimizasyonlar" FontSize="13" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButtonStyle}" Tag="Cleaner" Click="TabButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🧹  Hızlı Temizlik" FontSize="13" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButtonStyle}" Tag="Restore" Click="TabButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🛡️  Yedek &amp; Geri Yükle" FontSize="13" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="AdminTabButton" Style="{StaticResource SidebarButtonStyle}" Tag="Admin" Click="TabButton_Click" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔑  Key Oluşturma" FontSize="13" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Sidebar Footer Info -->
                        <StackPanel Grid.Row="2" Margin="5,0,0,5">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                                <Ellipse x:Name="OnlineIndicatorDot" Width="8" Height="8" Fill="#FF3366" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Ellipse.Effect>
                                        <DropShadowEffect x:Name="OnlineIndicatorGlow" Color="#FF3366" BlurRadius="6" ShadowDepth="0" Opacity="0.8"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock x:Name="OnlineIndicatorText" Text="Lisans Sunucusu: Kontrol ediliyor..." FontSize="10" Foreground="#FFAAAAAA" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Durum: Koruma Devrede" FontSize="11" Foreground="#00FFCC" Margin="0,0,0,2"/>
                            <TextBlock Text="Anti-Cheat Uyumlu: %100" FontSize="11" Foreground="#FFAAAAAA"/>
                            <TextBlock Text="İletişim: guns.lol/mustik34" FontSize="10" Foreground="#00FFCC" Cursor="Hand" MouseDown="DiscordLink_MouseDown" TextDecorations="Underline" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ================== MAIN CONTENT PANEL ================== -->
                <Grid Grid.Column="1" Margin="25,20,25,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top Custom Bar (Drag Handle & Controls) -->
                    <Grid Grid.Row="0" VerticalAlignment="Top" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Header text dynamically changes or stays global -->
                        <TextBlock Text="Kernel FPS Artırma - Mustik Dev" FontSize="13" Foreground="#88FFFFFF" VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="MinimizeButton" Content="—" Foreground="#88FFFFFF" Background="Transparent" BorderThickness="0" Width="30" Height="25" Click="MinimizeButton_Click" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button x:Name="CloseButton" Content="✕" Foreground="#88FFFFFF" Background="Transparent" BorderThickness="0" Width="30" Height="25" Click="CloseButton_Click" Margin="5,0,0,0" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="Red"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Tabs Container -->
                    <Grid Grid.Row="1">

                        <!-- TAB 1: DASHBOARD -->
                        <Grid x:Name="DashboardTab" Visibility="Visible">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Live Gauges (CPU & RAM) -->
                            <Grid Grid.Row="0" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- CPU Monitor Card -->
                                <Border Grid.Column="0" Background="#12FFFFFF" CornerRadius="10" Padding="20,15,20,15" BorderBrush="#15FFFFFF" BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="📊 İŞLEMCİ KULLANIMI" FontSize="11" Foreground="#FFAAAAAA" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <ProgressBar x:Name="CpuGauge" Grid.Row="1" Style="{StaticResource NeonProgressBarStyle}" Height="10" Value="24" Maximum="100"/>
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                            <TextBlock x:Name="CpuText" Text="24%" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- RAM Monitor Card -->
                                <Border Grid.Column="2" Background="#12FFFFFF" CornerRadius="10" Padding="20,15,20,15" BorderBrush="#15FFFFFF" BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="🧠 RAM KULLANIMI" FontSize="11" Foreground="#FFAAAAAA" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <ProgressBar x:Name="RamGauge" Grid.Row="1" Style="{StaticResource NeonProgressBarStyle}" Height="10" Value="48" Maximum="100"/>
                                        <Grid Grid.Row="2" Margin="0,8,0,0">
                                            <TextBlock x:Name="RamDetailText" Text="7.8 GB / 16.0 GB" FontSize="11" Foreground="#88FFFFFF" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="RamText" Text="48%" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Boost & Info Center -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="240"/>
                                </Grid.ColumnDefinitions>

                                <!-- Giant Quick Boost Module -->
                                <Border Grid.Column="0" Background="#15FFFFFF" CornerRadius="10" BorderBrush="#20FFFFFF" BorderThickness="1">
                                    <Grid Margin="20">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Pulse Animation Placeholder -->
                                        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,15">
                                            <TextBlock Text="🚀" FontSize="52" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Sistem optimize edilmeye hazır." FontSize="14" Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                            <TextBlock Text="Tek tıkla tüm çekirdek, RAM ve ağ ayarlarını optimize edin." FontSize="11" Foreground="#88FFFFFF" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,15"/>
                                            
                                            <!-- Profile Selector -->
                                            <TextBlock Text="🎯 AKTİF PERFORMANS PROFİLİ" FontSize="11" Foreground="#FFAAAAAA" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,8"/>
                                            <UniformGrid Columns="3" Width="380" Height="32">
                                                <RadioButton x:Name="RadioCompetitive" Content="⚡ Rekabetçi" Style="{StaticResource ProfileRadioButtonStyle}" IsChecked="True" GroupName="ProfileGroup" Checked="ProfileRadio_Checked"/>
                                                <RadioButton x:Name="RadioStory" Content="🎮 Hikaye" Style="{StaticResource ProfileRadioButtonStyle}" GroupName="ProfileGroup" Checked="ProfileRadio_Checked"/>
                                                <RadioButton x:Name="RadioBalanced" Content="⚖️ Dengeli" Style="{StaticResource ProfileRadioButtonStyle}" GroupName="ProfileGroup" Checked="ProfileRadio_Checked"/>
                                            </UniformGrid>
                                        </StackPanel>

                                        <!-- Boost Progress Glow Effect -->
                                        <ProgressBar x:Name="ProgressBarGlow" Grid.Row="1" IsIndeterminate="True" Style="{StaticResource NeonProgressBarStyle}" Height="4" Margin="10,0,10,15" Visibility="Collapsed"/>

                                        <!-- Boost Button -->
                                        <Button x:Name="QuickBoostButton" Grid.Row="2" Style="{StaticResource ActionButtonStyle}" Height="50" FontSize="16" Foreground="#0A0E1A" Click="QuickBoostButton_Click">
                                            <TextBlock x:Name="QuickBoostText" Text="HIZLANDIR" FontWeight="Bold"/>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- System Specs Module -->
                                <Border Grid.Column="2" Background="#10FFFFFF" CornerRadius="10" Padding="15" BorderBrush="#15FFFFFF" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="🖥️ SİSTEM BİLGİLERİ" FontSize="12" FontWeight="Bold" Foreground="#00FFCC" Margin="0,0,0,15"/>

                                        <TextBlock Text="İşlemci (CPU)" FontSize="10" Foreground="#88FFFFFF"/>
                                        <TextBlock x:Name="CpuSpecText" Text="Intel Core i7-12700H" FontSize="12" Foreground="White" Margin="0,2,0,12" TextWrapping="Wrap"/>

                                        <TextBlock Text="Grafik Kartı (GPU)" FontSize="10" Foreground="#88FFFFFF"/>
                                        <TextBlock x:Name="GpuSpecText" Text="NVIDIA GeForce RTX 3060" FontSize="12" Foreground="White" Margin="0,2,0,12" TextWrapping="Wrap"/>

                                        <TextBlock Text="Bellek (RAM)" FontSize="10" Foreground="#88FFFFFF"/>
                                        <TextBlock x:Name="RamSpecText" Text="16.0 GB DDR4" FontSize="12" Foreground="White" Margin="0,2,0,12"/>

                                        <TextBlock Text="İşletim Sistemi" FontSize="10" Foreground="#88FFFFFF"/>
                                        <TextBlock x:Name="OsSpecText" Text="Windows 11 Home 23H2" FontSize="12" Foreground="White"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- TAB 2: TWEAKS (SCROLLABLE LIST) -->
                        <Grid x:Name="TweaksTab" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Tweaks Header (Title + Restore Button) -->
                            <Grid Grid.Row="0" Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="⚡ Kernel ve Kayıt Defteri Optimizasyonları" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                <Button x:Name="TweaksRestoreButton" Grid.Column="1" Content="Tümünü Geri Al" Width="130" Height="30" Click="RestoreDefaultsButton_Click" VerticalAlignment="Center" Background="#FFFF4444" Foreground="White">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FFDD3333"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="TweaksContainer" Margin="0,0,10,0">
                                    <!-- Dynamic tweaks loaded here -->
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <!-- TAB 3: CLEANER -->
                        <Grid x:Name="CleanerTab" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="🧹 Hızlı Bellek ve Disk Temizliği" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>

                            <!-- Cache cleaning options -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Standby RAM Cleaner Card -->
                                <Border Grid.Column="0" Background="#12FFFFFF" CornerRadius="10" Padding="20" BorderBrush="#15FFFFFF" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="🧠 RAM Bekleme Listesi Temizleyici" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                                        <TextBlock Text="Windows'un arka planda önbelleğe alıp RAM'i doldurduğu Standby Listeyi temizler. Oyuna girmeden önce tıklandığında anlık kekelemeleri (stutter) önler." FontSize="11" Foreground="#88FFFFFF" TextWrapping="Wrap" Height="65"/>
                                        <TextBlock x:Name="RamCleanStatus" Text="Temizleme yapılmadı." FontSize="11" Foreground="#FFAAAAAA" Margin="0,10,0,10"/>
                                        <Button x:Name="CleanRamButton" Style="{StaticResource ActionButtonStyle}" Content="RAM Önbelleğini Temizle" Click="CleanRamButton_Click"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                            <CheckBox x:Name="BgRamCleanerToggle" Style="{StaticResource ModernToggleStyle}" Checked="BgRamCleanerToggle_Checked" Unchecked="BgRamCleanerToggle_Unchecked" VerticalAlignment="Center"/>
                                            <TextBlock Text="Kapanınca Arka Planda RAM Temizlemeye Devam Et" FontSize="11" Foreground="#CCFFFFFF" VerticalAlignment="Center" Margin="10,0,0,0" TextWrapping="Wrap" Width="220"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Disk Junk Cleaner Card -->
                                <Border Grid.Column="2" Background="#12FFFFFF" CornerRadius="10" Padding="20" BorderBrush="#15FFFFFF" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="🗑️ Disk Gereksiz Dosya Temizleyici" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                                        <TextBlock Text="Sistemdeki Temp, Prefetch ve geçici log dosyalarını tarar ve temizler. Disk okuma hızını artırır ve SSD/HDD üzerindeki ekstra yükleri temizler." FontSize="11" Foreground="#88FFFFFF" TextWrapping="Wrap" Height="65"/>
                                        <TextBlock x:Name="JunkCleanStatus" Text="Temizleme yapılmadı." FontSize="11" Foreground="#FFAAAAAA" Margin="0,10,0,10"/>
                                        <Button x:Name="CleanJunkButton" Style="{StaticResource ActionButtonStyle}" Content="Disk Çöpünü Temizle" Click="CleanJunkButton_Click"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- TAB 4: RESTORE / BACKUP -->
                        <Grid x:Name="RestoreTab" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="🛡️ Yedekleme ve Varsayılan Ayarlara Dönüş" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>

                            <Border Grid.Row="1" Background="#12FFFFFF" CornerRadius="10" Padding="25" BorderBrush="#15FFFFFF" BorderThickness="1" VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="Sistem Geri Yükleme Noktası" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                    <TextBlock Text="Herhangi bir ayarı yapmadan önce Windows üzerinde bir Geri Yükleme Noktası (Restore Point) oluşturmanız önemle tavsiye edilir. Sisteminizde bir sorun oluşması durumunda tek tıkla eski haline döndürebilirsiniz." FontSize="11" Foreground="#88FFFFFF" TextWrapping="Wrap" Margin="0,0,0,15"/>

                                    <Button x:Name="CreateRestorePointButton" Style="{StaticResource ActionButtonStyle}" Width="250" Content="Geri Yükleme Noktası Oluştur" Click="CreateRestorePointButton_Click" HorizontalAlignment="Left"/>

                                    <Separator Background="#20FFFFFF" Margin="0,25,0,25"/>

                                    <TextBlock Text="Fabrika Ayarlarına Geri Dön" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                    <TextBlock Text="Uygulanan tüm kayıt defteri (Registry) tweakslerini ve Windows optimizasyonlarını orijinal durumlarına geri döndürür. Ayarların aktifleşmesi için PC yeniden başlatılmalıdır." FontSize="11" Foreground="#88FFFFFF" TextWrapping="Wrap" Margin="0,0,0,15"/>

                                    <Button x:Name="RestoreDefaultsButton" Width="250" Content="Windows Varsayılanlarına Sıfırla" Click="RestoreDefaultsButton_Click" HorizontalAlignment="Left" Background="#FFFF4444" Foreground="White">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FFDD3333"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <TextBlock x:Name="RestoreStatusText" Text="" FontSize="11" Foreground="#FFAAAAAA" Margin="0,20,0,0" TextWrapping="Wrap"/>

                                    <Separator Background="#20FFFFFF" Margin="0,25,0,25"/>

                                    <TextBlock Text="Lisans Anahtarını Değiştir" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                    <TextBlock Text="Bu bilgisayardaki aktif lisans anahtarını siler ve farklı bir lisans anahtarı girebileceğiniz giriş ekranını açar." FontSize="11" Foreground="#88FFFFFF" TextWrapping="Wrap" Margin="0,0,0,15"/>

                                    <Button x:Name="ChangeLicenseButton" Width="250" Content="Lisansı Değiştir / Farklı Key Yaz" Click="ChangeLicenseButton_Click" HorizontalAlignment="Left" Background="#FF00CC" Foreground="White">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FF00AA"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- TAB 5: ADMIN KEY GENERATOR -->
                        <Grid x:Name="AdminTab" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="🔑 Admin Key Üretim Paneli" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>

                            <Border Grid.Row="1" Background="#12FFFFFF" CornerRadius="10" Padding="25" BorderBrush="#15FFFFFF" BorderThickness="1" VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="Bulut Veritabanı Üzerinde Lisans Anahtarı Oluşturun" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                    <TextBlock Text="Oluşturulan keyler doğrudan canlı Firebase real-time database üzerine kaydedilir ve hemen kullanılabilir hale gelir." FontSize="11" Foreground="#88FFFFFF" TextWrapping="Wrap" Margin="0,0,0,20"/>

                                    <!-- Key Type Selector (1-Day, 30-Day, Unlimited) -->
                                    <TextBlock Text="Süre Seçin" FontSize="11" Foreground="#FFAAAAAA" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Grid Margin="0,0,0,20" Height="40">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <RadioButton x:Name="Radio1Day" Grid.Column="0" Content="1 Günlük Key" Style="{StaticResource ProfileRadioButtonStyle}" IsChecked="True" GroupName="AdminKeyTypeGroup"/>
                                        <RadioButton x:Name="Radio30Day" Grid.Column="2" Content="30 Günlük Key" Style="{StaticResource ProfileRadioButtonStyle}" GroupName="AdminKeyTypeGroup"/>
                                        <RadioButton x:Name="RadioUnlim" Grid.Column="4" Content="Sınırsız VIP Key" Style="{StaticResource ProfileRadioButtonStyle}" GroupName="AdminKeyTypeGroup"/>
                                    </Grid>

                                    <!-- Action Button -->
                                    <Button x:Name="GenerateKeyButton" Style="{StaticResource ActionButtonStyle}" Width="250" Content="Lisans Anahtarı Üret" Click="GenerateKeyButton_Click" HorizontalAlignment="Left" Margin="0,0,0,25"/>

                                    <Separator Background="#20FFFFFF" Margin="0,5,0,25"/>

                                    <!-- Output Field -->
                                    <TextBlock Text="Üretilen Lisans Anahtarı" FontSize="11" Foreground="#FFAAAAAA" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Grid x:Name="GeneratedKeyContainer" Visibility="Collapsed" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="15"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#15FFFFFF" BorderBrush="#25FFFFFF" BorderThickness="1" CornerRadius="6" Height="42" Padding="15,2">
                                            <TextBox x:Name="GeneratedKeyBox" Background="Transparent" Foreground="Yellow" BorderThickness="0" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" IsReadOnly="True"/>
                                        </Border>
                                        <Button x:Name="CopyKeyButton" Grid.Column="2" Content="Kopyala" Style="{StaticResource ActionButtonStyle}" Height="42" Click="CopyKeyButton_Click"/>
                                    </Grid>
                                    <TextBlock x:Name="GeneratedKeyStatusText" Text="" FontSize="11" Foreground="#FFAAAAAA" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                    </Grid>
                </Grid>
            </Grid>

                <!-- ================== ACTIVATION OVERLAY ================== -->
                <Grid x:Name="ActivationOverlay" Visibility="Collapsed">
                    <Border CornerRadius="11" Background="#F50A0E1A">
                        <Grid Margin="40" MaxWidth="500" VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Lock Emoji & Title -->
                            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,25">
                                <TextBlock Text="🔒" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="ANAKART KİLİDİ AKTİF" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#FF00CC" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="Lütfen programı kullanmak için geçerli bir lisans key girin." FontSize="12" Foreground="#88FFFFFF" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>

                            <!-- HWID Display Card -->
                            <Border Grid.Row="1" Background="#12FFFFFF" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="🖥️ BİLGİSAYARINIZIN LİSANS ANAKART ID'Sİ (HWID):" FontSize="11" Foreground="#00FFCC" FontWeight="Bold" Margin="0,0,0,5"/>
                                    <TextBox x:Name="HwidDisplayBox" Text="HWID LOADING..." FontSize="12" Foreground="Yellow" Background="Transparent" BorderThickness="0" IsReadOnly="True" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <!-- License Key Input Field -->
                            <StackPanel Grid.Row="2" Margin="0,0,0,20">
                                <TextBlock Text="🔑 LİSANS ANAHTARI" FontSize="11" Foreground="#FFAAAAAA" FontWeight="Bold" Margin="0,0,0,8"/>
                                <Border Background="#15FFFFFF" BorderBrush="#25FFFFFF" BorderThickness="1" CornerRadius="6" Height="42" Padding="8,2">
                                    <Grid>
                                        <TextBox x:Name="LicenseInputBox" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14" VerticalAlignment="Center" CaretBrush="White" GotFocus="LicenseInputBox_GotFocus" LostFocus="LicenseInputBox_LostFocus"/>
                                        <TextBlock x:Name="LicenseWatermark" Text="Örn: MUSTIK-VIP-5090-RTX" Foreground="#44FFFFFF" FontSize="14" VerticalAlignment="Center" IsHitTestVisible="False" Margin="4,0,0,0"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- Activation Status Label -->
                            <TextBlock x:Name="ActivationStatusText" Grid.Row="3" Text="" Foreground="#FFFF4444" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                            <!-- Action Buttons -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="ActivateButton" Grid.Column="0" Style="{StaticResource ActionButtonStyle}" Height="45" Click="ActivateButton_Click">
                                    <TextBlock Text="LİSANSI AKTİF ET" FontWeight="Bold" FontSize="14"/>
                                </Button>
                                <Button x:Name="ActivationExitButton" Grid.Column="2" Content="Çıkış" Background="#33FFFFFF" Foreground="White" BorderThickness="0" Height="45" Click="CloseButton_Click">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#55FFFFFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
</Window>


